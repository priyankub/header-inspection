{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "platformAutomerge": true,
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "packageRules": [
    {
      "matchCategories": [
        "golang"
      ],
      "postUpdateOptions": [
        "gomodTidy"
      ]
    },
    {
      "matchManagers": ["gomod", "dockerfile", "github-actions"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "groupName": "All Homelab Dependencies",
      "groupSlug": "all-homelab-deps",
      "description": "Squash all incoming updates into a single branch to eliminate separate commit noise.",
      "matchPackageNames": [
        "*"
      ]
    }
  ]
}
